# ============================================================
#  .env.example  |  이 파일을 복사해서 .env 로 저장 후 키 입력
#  cp .env.example .env
# ============================================================

# ── 날씨 ──────────────────────────────────────────────────
OPENWEATHER_API_KEY=your_openweather_api_key_here
CITY=Seoul

# ── OpenAI (코디 생성) ────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here
# 선택: 기본 gpt-4o-mini
# OPENAI_MODEL=gpt-4o

# ── 이미지 (Unsplash Access Key 권장 — 없으면 Naver 사용) ──
# https://unsplash.com/oauth/applications
UNSPLASH_ACCESS_KEY=

# ── Naver 검색 (이미지 폴백 / Unsplash 미설정 시) ────────
NAVER_CLIENT_ID=your_naver_client_id_here
NAVER_CLIENT_SECRET=your_naver_client_secret_here

# ── 카카오톡 ──────────────────────────────────────────────
KAKAO_REST_API_KEY=your_kakao_rest_api_key_here
KAKAO_ACCESS_TOKEN=your_kakao_access_token_here
KAKAO_REFRESH_TOKEN=your_kakao_refresh_token_here
